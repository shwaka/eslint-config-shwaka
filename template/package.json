{
  "name": "template",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "tsc": "tsc -b",
    "tsc-watch": "tsc -b --watch",
    "eslint": "eslint src",
    "eslint:fix": "eslint src --fix",
    "eslint:onsave": "eslint --config eslint-onsave.config.js --fix",
    "eslint:watch": "chokidar 'src/**/*' --initial --command 'clear && npm run eslint'",
    "lc": "npm run eslint",
    "lf": "npm run eslint:fix",
    "test": "vitest run",
    "test-watch": "vitest"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "chokidar-cli": "^3.0.0",
    "eslint": "^9.30.1",
    "eslint-config-shwaka": "git+https://github.com/shwaka/eslint-config-shwaka#v3.8",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "jsdom": "^26.1.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.35.1",
    "vite": "^7.0.4",
    "vitest": "^3.2.4"
  }
}
